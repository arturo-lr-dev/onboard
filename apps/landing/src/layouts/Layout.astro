---
import { languages, getLocalizedPath, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: Lang;
}

const { lang = defaultLang, title, description = '', image = "/og-image.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4WZ2L1ZNMN"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4WZ2L1ZNMN');
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","vryvc4518o");
    </script>

    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates -->
    {Object.keys(languages).map(l => (
      <link rel="alternate" hreflang={l} href={new URL(getLocalizedPath(l as Lang, '/'), Astro.site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Onboard" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Onboard",
          "url": Astro.site?.toString(),
          "description": description
        },
        {
          "@type": "WebSite",
          "name": "Onboard",
          "url": Astro.site?.toString()
        }
      ]
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="grain"></div>
    <slot />

    <!-- GA4 custom events + UTM tracking -->
    <script is:inline>
      // Persist UTM params to sessionStorage
      (function() {
        var params = new URLSearchParams(window.location.search);
        var utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
        utmKeys.forEach(function(key) {
          var val = params.get(key);
          if (val) sessionStorage.setItem(key, val);
        });
      })();

      // Track CTA clicks (all links/buttons pointing to #contact)
      document.addEventListener('click', function(e) {
        var el = e.target.closest('a[href="#contact"], a[href*="#contact"]');
        if (el && typeof gtag === 'function') {
          gtag('event', 'cta_click', {
            event_category: 'engagement',
            event_label: el.textContent.trim().substring(0, 50),
            utm_source: sessionStorage.getItem('utm_source') || '(direct)',
            utm_medium: sessionStorage.getItem('utm_medium') || '(none)',
            utm_campaign: sessionStorage.getItem('utm_campaign') || '(none)'
          });
        }
      });

      // Track pricing/contact section view via IntersectionObserver
      var observedSections = {};
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && !observedSections[entry.target.id]) {
            observedSections[entry.target.id] = true;
            if (typeof gtag === 'function') {
              gtag('event', entry.target.id + '_view', {
                event_category: 'engagement',
                utm_source: sessionStorage.getItem('utm_source') || '(direct)'
              });
            }
          }
        });
      }, { threshold: 0.3 });

      ['contact', 'problem', 'solution', 'who'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) observer.observe(el);
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
