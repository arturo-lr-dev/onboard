---
import { useTranslations, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<div class="relative border border-[var(--border)] p-8 md:p-10">
  <!-- Corner accents -->
  <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-[var(--lime)] -translate-x-px -translate-y-px"></div>
  <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-[var(--lime)] translate-x-px -translate-y-px"></div>
  <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-[var(--lime)] -translate-x-px translate-y-px"></div>
  <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-[var(--lime)] translate-x-px translate-y-px"></div>

  <h3 class="heading-display text-2xl md:text-3xl mb-2">{t.contactForm.requestAccess}</h3>
  <p class="text-[var(--text-secondary)] mb-8 text-sm">{t.contactForm.spotsDesc}</p>

  <form
    id="contact-form"
    action="https://formspree.io/f/xreygybr"
    method="POST"
    data-transmitting={t.contactForm.transmitting}
    data-join-waitlist={t.contactForm.joinWaitlist}
  >
    <!-- Step 1: Email only (always visible) -->
    <div id="form-step-1">
      <label for="email" class="section-label block mb-2">{t.contactForm.workEmail}</label>
      <div class="flex gap-3">
        <input
          type="email"
          id="email"
          name="email"
          required
          class="flex-1 bg-[var(--bg)] border border-[var(--border)] px-4 py-3 text-sm mono placeholder:text-[var(--text-tertiary)] focus:outline-none focus:border-[var(--lime)] transition-colors"
          placeholder={t.hero.emailPlaceholder}
        />
        <button
          type="button"
          id="continue-btn"
          class="btn-primary !py-3 whitespace-nowrap"
        >
          {t.contactForm.continue}
        </button>
      </div>
      <p class="text-xs text-[var(--text-tertiary)] mt-2 mono">{t.contactForm.noSpam}</p>
    </div>

    <!-- Step 2: Details (revealed after email) -->
    <div id="form-step-2" class="hidden mt-6 space-y-5" style="display:none;">
      <div class="divider-lime mb-6"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label for="name" class="section-label block mb-2">{t.contactForm.nameLabel}</label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full bg-[var(--bg)] border border-[var(--border)] px-4 py-3 text-sm mono placeholder:text-[var(--text-tertiary)] focus:outline-none focus:border-[var(--lime)] transition-colors"
            placeholder={t.contactForm.namePlaceholder}
          />
        </div>

        <div>
          <label for="company" class="section-label block mb-2">{t.contactForm.companyLabel}</label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full bg-[var(--bg)] border border-[var(--border)] px-4 py-3 text-sm mono placeholder:text-[var(--text-tertiary)] focus:outline-none focus:border-[var(--lime)] transition-colors"
            placeholder={t.contactForm.companyPlaceholder}
          />
        </div>
      </div>

      <div>
        <label for="agents" class="section-label block mb-2">{t.contactForm.agentsLabel}</label>
        <select
          id="agents"
          name="agents"
          class="w-full bg-[var(--bg)] border border-[var(--border)] px-4 py-3 text-sm mono text-[var(--text-secondary)] focus:outline-none focus:border-[var(--lime)] transition-colors"
        >
          <option value="">{t.contactForm.agentsSelect}</option>
          <option value="0">{t.contactForm.agentsNone}</option>
          <option value="1-5">{t.contactForm.agents1to5}</option>
          <option value="6-20">{t.contactForm.agents6to20}</option>
          <option value="21+">{t.contactForm.agents21plus}</option>
        </select>
      </div>

      <button type="submit" id="submit-btn" class="btn-primary w-full justify-center mt-2">
        {t.contactForm.joinWaitlist}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </button>

      <button type="submit" id="skip-btn" class="w-full text-center text-xs mono text-[var(--text-tertiary)] hover:text-[var(--lime)] transition-colors cursor-pointer mt-1 bg-transparent border-none">
        {t.contactForm.skipDetails}
      </button>
    </div>

    <!-- Step 3: Success state -->
    <div id="form-success" style="display:none;" class="text-center py-8">
      <div class="w-12 h-12 border-2 border-[var(--lime)] flex items-center justify-center mx-auto mb-4">
        <svg class="w-6 h-6 text-[var(--lime)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h4 class="heading-display text-xl mb-2">{t.contactForm.successTitle}</h4>
      <p class="text-sm text-[var(--text-secondary)] mono">{t.contactForm.successDesc}</p>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const step1 = document.getElementById('form-step-1') as HTMLElement;
  const step2 = document.getElementById('form-step-2') as HTMLElement;
  const success = document.getElementById('form-success') as HTMLElement;
  const continueBtn = document.getElementById('continue-btn') as HTMLButtonElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;

  const transmittingText = form?.dataset.transmitting || 'TRANSMITTING...';
  const joinWaitlistText = form?.dataset.joinWaitlist || 'Join the Waitlist';

  // Step 1 -> Step 2
  continueBtn?.addEventListener('click', () => {
    if (!emailInput.value || !emailInput.validity.valid) {
      emailInput.focus();
      emailInput.reportValidity();
      return;
    }
    step2.style.display = 'block';
    step2.classList.remove('hidden');
    continueBtn.textContent = '';
    continueBtn.style.display = 'none';
    // Focus first field in step 2
    (document.getElementById('name') as HTMLInputElement)?.focus();
  });

  // Allow Enter on email to continue
  emailInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      continueBtn.click();
    }
  });

  // Submit handler
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const skipBtn = document.getElementById('skip-btn') as HTMLButtonElement;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = `<span class="animate-pulse">${transmittingText}</span>`;
    }
    if (skipBtn) skipBtn.style.display = 'none';

    try {
      const formData = new FormData(form);
      await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      // GA4: track email submission
      if (typeof gtag === 'function') {
        gtag('event', 'email_submit', {
          event_category: 'conversion',
          utm_source: sessionStorage.getItem('utm_source') || '(direct)',
          utm_medium: sessionStorage.getItem('utm_medium') || '(none)',
          utm_campaign: sessionStorage.getItem('utm_campaign') || '(none)'
        });
      }

      step1.style.display = 'none';
      step2.style.display = 'none';
      success.style.display = 'block';
    } catch {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `${joinWaitlistText} <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>`;
      }
    }
  });
</script>
