---
import { languages, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  currentLang: Lang;
}

const { currentLang } = Astro.props;
---

<div class="relative" id="lang-switcher">
  <button class="section-label flex items-center gap-1 hover:text-[var(--text-primary)] transition-colors uppercase" aria-label="Select language">
    {currentLang}
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div class="absolute top-full right-0 mt-2 bg-[var(--bg-elevated)] border border-[var(--border)] py-1 hidden min-w-[120px] z-50" id="lang-dropdown">
    {Object.entries(languages).map(([code, name]) => (
      <a
        href={getLocalizedPath(code as Lang)}
        class:list={[
          'block px-4 py-2 text-xs mono hover:bg-[var(--lime)] hover:text-[var(--bg)] transition-colors',
          code === currentLang ? 'text-[var(--lime)]' : 'text-[var(--text-secondary)]'
        ]}
      >
        {code.toUpperCase()} - {name}
      </a>
    ))}
  </div>
</div>

<script>
  const btn = document.querySelector('#lang-switcher button');
  const dropdown = document.getElementById('lang-dropdown');
  btn?.addEventListener('click', () => dropdown?.classList.toggle('hidden'));
  document.addEventListener('click', (e) => {
    if (!document.getElementById('lang-switcher')?.contains(e.target as Node)) {
      dropdown?.classList.add('hidden');
    }
  });
</script>
