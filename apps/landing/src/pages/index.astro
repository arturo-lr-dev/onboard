---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Onboard - Enterprise AI Agent Onboarding">
  <main class="min-h-screen">

    <!-- Navigation -->
    <nav class="fixed top-0 w-full z-50 border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-2 sm:gap-3">
          <div class="w-2 h-2 bg-[var(--lime)] animate-pulse-glow"></div>
          <span class="mono text-sm font-bold tracking-wider">ONBOARD</span>
        </div>
        <div class="hidden md:flex items-center gap-8">
          <a href="#problem" class="section-label hover:text-[var(--text-primary)] transition-colors">Problem</a>
          <a href="#solution" class="section-label hover:text-[var(--text-primary)] transition-colors">Solution</a>
          <a href="#who" class="section-label hover:text-[var(--text-primary)] transition-colors">Who</a>
          <a href="#contact" class="section-label hover:text-[var(--text-primary)] transition-colors">Access</a>
        </div>
        <a href="#contact" class="btn-primary !py-2 !px-3 sm:!px-4 text-[10px] sm:text-xs">
          Get Access
        </a>
      </div>
    </nav>

    <!-- ============================== -->
    <!-- HERO -->
    <!-- ============================== -->
    <section class="relative pt-24 sm:pt-28 pb-12 sm:pb-16 px-4 sm:px-6 min-h-screen flex items-center">
      <div class="absolute inset-0 dot-grid opacity-30 pointer-events-none"></div>
      <div class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-[var(--lime)] rounded-full opacity-[0.02] blur-[120px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto relative z-10 w-full">
        <div class="grid lg:grid-cols-[1.1fr,1fr] gap-10 lg:gap-16 items-center">

          <!-- Left: Copy + email capture -->
          <div class="stagger-in">
            <div class="flex items-center gap-3 mb-6 sm:mb-8">
              <div class="section-number">01</div>
              <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
              <div class="section-label">System Overview</div>
            </div>

            <h1 class="heading-display text-[clamp(2.25rem,7vw,6rem)] mb-5 sm:mb-6">
              Enterprise-Grade<br/>
              <span class="text-[var(--lime)]">Onboarding</span><br/>
              for AI Agents
            </h1>

            <p class="text-base sm:text-lg text-[var(--text-secondary)] mb-6 sm:mb-8 max-w-xl leading-relaxed">
              Stop deploying agents blindly. Give them context, access, and compliance from day one.
            </p>

            <!-- Inline email capture -->
            <form id="hero-email" class="flex flex-col sm:flex-row gap-3 max-w-md mb-4 sm:mb-6" action="https://formspree.io/f/xreygybr" method="POST">
              <input
                type="email"
                name="email"
                required
                class="flex-1 bg-[var(--bg-elevated)] border border-[var(--border)] px-4 py-3 sm:py-3.5 text-sm mono placeholder:text-[var(--text-tertiary)] focus:outline-none focus:border-[var(--lime)] transition-colors"
                placeholder="you@company.com"
              />
              <input type="hidden" name="_source" value="hero" />
              <button type="submit" class="btn-primary !py-3 sm:!py-3.5 whitespace-nowrap justify-center sm:justify-start">
                Get Access
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </button>
            </form>

            <p class="text-xs text-[var(--text-tertiary)] mono mb-8 sm:mb-10">
              Free for pilot companies. <span class="text-[var(--lime)]">12 spots remaining.</span>
            </p>

            <!-- Stats row -->
            <div class="divider-lime max-w-md mb-6 sm:mb-8"></div>
            <div class="grid grid-cols-3 max-w-md">
              <div class="pr-4 sm:pr-6">
                <div class="mono text-xl sm:text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-1">Hours</div>
                <div class="section-label text-[9px] sm:text-[11px]">not weeks to prod</div>
              </div>
              <div class="px-4 sm:px-6 border-l border-[var(--border)]">
                <div class="mono text-xl sm:text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-1">100%</div>
                <div class="section-label text-[9px] sm:text-[11px]">compliant day one</div>
              </div>
              <div class="pl-4 sm:pl-6 border-l border-[var(--border)]">
                <div class="mono text-xl sm:text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-1">Zero</div>
                <div class="section-label text-[9px] sm:text-[11px]">security gaps</div>
              </div>
            </div>
          </div>

          <!-- Right: Terminal mockup -->
          <div class="hidden lg:block">
            <div class="terminal rounded-lg shadow-2xl shadow-black/50" id="hero-terminal">
              <div class="terminal-bar">
                <div class="terminal-dot bg-[#FF5F57]"></div>
                <div class="terminal-dot bg-[#FEBC2E]"></div>
                <div class="terminal-dot bg-[#28C840]"></div>
                <span class="ml-3 text-[10px] text-[var(--text-tertiary)] mono">onboard deploy --agent sales-copilot</span>
              </div>
              <div class="p-5 space-y-1 min-h-[340px]" id="terminal-output">
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
        <div class="section-label">Scroll</div>
        <div class="w-px h-6 sm:h-8 bg-gradient-to-b from-[var(--text-tertiary)] to-transparent"></div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- SOCIAL PROOF BAR -->
    <!-- ============================== -->
    <div class="border-y border-[var(--border)] bg-[var(--bg-elevated)] py-4 sm:py-5 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-6 md:gap-10">
        <span class="section-label text-[var(--text-tertiary)]">Teams from</span>
        <div class="flex items-center gap-4 sm:gap-6 md:gap-12 opacity-40">
          <span class="mono text-[10px] sm:text-sm font-bold tracking-wider">YC STARTUPS</span>
          <span class="mono text-[10px] sm:text-sm font-bold tracking-wider">SERIES A+</span>
          <span class="mono text-[10px] sm:text-sm font-bold tracking-wider">ENTERPRISE</span>
          <span class="mono text-[10px] sm:text-sm font-bold tracking-wider hidden sm:block">AI-FIRST COS</span>
        </div>
        <span class="section-label text-[var(--text-tertiary)]">are on the waitlist</span>
      </div>
    </div>

    <!-- ============================== -->
    <!-- PROBLEM: Before / After -->
    <!-- ============================== -->
    <section id="problem" class="section-reveal py-16 sm:py-24 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-8 sm:mb-10">
          <div class="section-number">02</div>
          <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
          <div class="section-label">Problem Space</div>
        </div>

        <div class="max-w-3xl mb-10 sm:mb-16">
          <h2 class="heading-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4 sm:mb-6">
            You Wouldn't Hire<br/>
            a Human Without<br/>
            <span class="text-[var(--text-tertiary)]">Onboarding</span>
          </h2>
          <p class="text-[var(--text-secondary)] leading-relaxed text-base sm:text-lg">
            When you bring on a new employee, there's a process. When you deploy an AI agent? Total chaos.
          </p>
        </div>

        <!-- Before / After comparison -->
        <div class="grid md:grid-cols-2 gap-px bg-[var(--border)] mb-10 sm:mb-16">
          <!-- WITHOUT -->
          <div class="bg-[var(--bg)] p-5 sm:p-8 comparison-without relative">
            <div class="flex items-center gap-2 mb-4 sm:mb-6">
              <div class="w-2 h-2 bg-[var(--red)] rounded-full"></div>
              <span class="mono text-[10px] sm:text-xs font-bold text-[var(--red)] tracking-wider">WITHOUT ONBOARD</span>
            </div>
            <ul class="space-y-3 sm:space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-[var(--red)] mono text-xs mt-0.5 shrink-0">--</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Ad-hoc credential sharing</div>
                  <div class="text-xs text-[var(--text-secondary)]">Slack DMs, shared passwords, zero audit trails</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--red)] mono text-xs mt-0.5 shrink-0">--</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Weeks to production</div>
                  <div class="text-xs text-[var(--text-secondary)]">Manual context loading, custom integrations</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--red)] mono text-xs mt-0.5 shrink-0">--</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Compliance blindspots</div>
                  <div class="text-xs text-[var(--text-secondary)]">No policy enforcement, regulators will notice</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--red)] mono text-xs mt-0.5 shrink-0">--</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Doesn't scale</div>
                  <div class="text-xs text-[var(--text-secondary)]">Agent #10 is just as painful as agent #1</div>
                </div>
              </li>
            </ul>
          </div>

          <!-- WITH -->
          <div class="bg-[var(--bg)] p-5 sm:p-8 comparison-with relative">
            <div class="flex items-center gap-2 mb-4 sm:mb-6">
              <div class="w-2 h-2 bg-[var(--lime)] rounded-full"></div>
              <span class="mono text-[10px] sm:text-xs font-bold text-[var(--lime)] tracking-wider">WITH ONBOARD</span>
            </div>
            <ul class="space-y-3 sm:space-y-4">
              <li class="flex items-start gap-3">
                <span class="text-[var(--lime)] mono text-xs mt-0.5 shrink-0">++</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Automated access management</div>
                  <div class="text-xs text-[var(--text-secondary)]">Role-based permissions, secret rotation, full audit</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--lime)] mono text-xs mt-0.5 shrink-0">++</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Hours to production</div>
                  <div class="text-xs text-[var(--text-secondary)]">Pre-loaded context, one-click integrations</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--lime)] mono text-xs mt-0.5 shrink-0">++</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">SOC2-ready from day one</div>
                  <div class="text-xs text-[var(--text-secondary)]">Built-in policy enforcement, audit trails</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[var(--lime)] mono text-xs mt-0.5 shrink-0">++</span>
                <div>
                  <div class="font-bold text-sm mb-0.5">Deploy 100 agents like 1</div>
                  <div class="text-xs text-[var(--text-secondary)]">Template-based onboarding, scales infinitely</div>
                </div>
              </li>
            </ul>
          </div>
        </div>

        <div class="text-center">
          <a href="#contact" class="btn-ghost">
            Fix this for your team
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ============================== -->
    <!-- SOLUTION -->
    <!-- ============================== -->
    <section id="solution" class="section-reveal py-16 sm:py-24 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-8 sm:mb-10">
          <div class="section-number">03</div>
          <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
          <div class="section-label">Solution Architecture</div>
        </div>

        <div class="max-w-3xl mb-10 sm:mb-16">
          <h2 class="heading-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4 sm:mb-6">
            The Infrastructure Layer<br/>
            <span class="text-[var(--lime)]">AI Ops Has Been Missing</span>
          </h2>
          <p class="text-[var(--text-secondary)] text-base sm:text-lg leading-relaxed">
            Onboard makes deploying AI agents as structured and secure as hiring humans.
          </p>
        </div>

        <!-- Features -->
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-px bg-[var(--border)]">
          <div class="bg-[var(--bg)] p-6 sm:p-8 card-hover group">
            <div class="w-10 h-10 border border-[var(--border)] flex items-center justify-center mb-5 sm:mb-6 group-hover:border-[var(--lime)] transition-colors">
              <svg class="w-5 h-5 text-[var(--lime)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="section-label mb-2 sm:mb-3">Module A</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">Context Loading</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Upload org structure, processes, culture docs. Agents start with full company context from day one.
            </p>
            <div class="divider-lime mt-5 sm:mt-6 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <div class="bg-[var(--bg)] p-6 sm:p-8 card-hover group">
            <div class="w-10 h-10 border border-[var(--border)] flex items-center justify-center mb-5 sm:mb-6 group-hover:border-[var(--lime)] transition-colors">
              <svg class="w-5 h-5 text-[var(--lime)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <div class="section-label mb-2 sm:mb-3">Module B</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">Access Management</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Role-based permissions, automated secret rotation, zero ad-hoc credential sharing. Security built-in.
            </p>
            <div class="divider-lime mt-5 sm:mt-6 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <div class="bg-[var(--bg)] p-6 sm:p-8 card-hover group sm:col-span-2 md:col-span-1">
            <div class="w-10 h-10 border border-[var(--border)] flex items-center justify-center mb-5 sm:mb-6 group-hover:border-[var(--lime)] transition-colors">
              <svg class="w-5 h-5 text-[var(--lime)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="section-label mb-2 sm:mb-3">Module C</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">Compliance Ready</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Audit trails, policy enforcement, SOC2-ready logs. Regulators happy, security team happy.
            </p>
            <div class="divider-lime mt-5 sm:mt-6 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ============================== -->
    <!-- HOW IT WORKS -->
    <!-- ============================== -->
    <section class="section-reveal py-16 sm:py-24 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-8 sm:mb-10">
          <div class="section-number">04</div>
          <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
          <div class="section-label">Process Flow</div>
        </div>

        <h2 class="heading-display text-3xl sm:text-4xl md:text-5xl mb-10 sm:mb-16">
          Three Steps to<br/>
          <span class="text-[var(--lime)]">Production-Ready</span>
        </h2>

        <div class="grid sm:grid-cols-3 gap-8 sm:gap-12">
          <div class="relative">
            <div class="mono text-5xl sm:text-6xl font-bold text-[var(--border)] mb-3 sm:mb-4">01</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Define</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Upload your org's context: culture docs, tool access policies, compliance requirements, team structure.
            </p>
            <div class="hidden sm:block absolute top-8 -right-6 w-12 h-px bg-[var(--border)]"></div>
          </div>

          <div class="relative">
            <div class="mono text-5xl sm:text-6xl font-bold text-[var(--border)] mb-3 sm:mb-4">02</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Configure</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Set role-based permissions, connect integrations, define guardrails and escalation paths.
            </p>
            <div class="hidden sm:block absolute top-8 -right-6 w-12 h-px bg-[var(--border)]"></div>
          </div>

          <div>
            <div class="mono text-5xl sm:text-6xl font-bold text-[var(--border)] mb-3 sm:mb-4">03</div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Deploy</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              Launch agents with full context, proper access, and complete audit trails. Scale from 1 to 100.
            </p>
          </div>
        </div>

        <div class="text-center mt-10 sm:mt-16">
          <a href="#contact" class="btn-primary">
            Start Onboarding Agents
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ============================== -->
    <!-- WHO IT'S FOR -->
    <!-- ============================== -->
    <section id="who" class="section-reveal py-16 sm:py-24 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center gap-3 mb-8 sm:mb-10">
          <div class="section-number">05</div>
          <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
          <div class="section-label">Target Profiles</div>
        </div>

        <div class="max-w-3xl mb-10 sm:mb-16">
          <h2 class="heading-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4 sm:mb-6">
            Built for Teams<br/>
            <span class="text-[var(--lime)]">Deploying AI at Scale</span>
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">
          <div class="border border-[var(--border)] p-6 sm:p-8 card-hover glow-ring group">
            <div class="mono text-[10px] sm:text-xs text-[var(--lime)] mb-3 sm:mb-4 tracking-wider">CTO / VP ENGINEERING</div>
            <h3 class="text-base sm:text-lg font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">"We have 15 agents but zero governance"</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              You need visibility, compliance, and standardized deployment before the board asks questions.
            </p>
          </div>

          <div class="border border-[var(--border)] p-6 sm:p-8 card-hover glow-ring group">
            <div class="mono text-[10px] sm:text-xs text-[var(--lime)] mb-3 sm:mb-4 tracking-wider">AI / ML ENGINEER</div>
            <h3 class="text-base sm:text-lg font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">"Each new agent takes 2 weeks to configure"</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              You're tired of writing the same integration code. You want templates, guardrails, and one-click deploys.
            </p>
          </div>

          <div class="border border-[var(--border)] p-6 sm:p-8 card-hover glow-ring group sm:col-span-2 md:col-span-1">
            <div class="mono text-[10px] sm:text-xs text-[var(--lime)] mb-3 sm:mb-4 tracking-wider">HEAD OF SECURITY</div>
            <h3 class="text-base sm:text-lg font-bold mb-2 sm:mb-3 group-hover:text-[var(--lime)] transition-colors">"AI agents are our biggest blind spot"</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              You need audit trails, permission boundaries, and SOC2-ready logging for every agent interaction.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ============================== -->
    <!-- CONTACT -->
    <!-- ============================== -->
    <section id="contact" class="section-reveal py-16 sm:py-24 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-[1fr,1.2fr] gap-10 sm:gap-16 items-start">
          <div>
            <div class="flex items-center gap-3 mb-8 sm:mb-10">
              <div class="section-number">06</div>
              <div class="w-8 sm:w-12 h-px bg-[var(--lime)]"></div>
              <div class="section-label">Early Access</div>
            </div>

            <h2 class="heading-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4 sm:mb-6">
              Ready to Deploy<br/>
              Agents<br/>
              <span class="text-[var(--lime)]">The Right Way?</span>
            </h2>
            <p class="text-[var(--text-secondary)] text-base sm:text-lg leading-relaxed mb-6 sm:mb-8">
              Pilot companies get hands-on setup support and influence the roadmap.
            </p>

            <div class="space-y-2 sm:space-y-3 mb-6 sm:mb-8">
              <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)]">
                <div class="w-1.5 h-1.5 bg-[var(--lime)] shrink-0"></div>
                Free during pilot period
              </div>
              <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)]">
                <div class="w-1.5 h-1.5 bg-[var(--lime)] shrink-0"></div>
                1-on-1 onboarding support
              </div>
              <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)]">
                <div class="w-1.5 h-1.5 bg-[var(--lime)] shrink-0"></div>
                Shape the product with your feedback
              </div>
              <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)]">
                <div class="w-1.5 h-1.5 bg-[var(--lime)] shrink-0"></div>
                SOC2 compliant infrastructure
              </div>
            </div>

            <!-- Urgency -->
            <div class="border border-[var(--border)] p-3 sm:p-4 bg-[var(--bg-elevated)]">
              <div class="flex items-center gap-2 mb-1">
                <div class="w-1.5 h-1.5 bg-[var(--red)] rounded-full animate-pulse"></div>
                <span class="mono text-[10px] sm:text-xs font-bold text-[var(--text-primary)]">LIMITED AVAILABILITY</span>
              </div>
              <p class="text-[10px] sm:text-xs text-[var(--text-secondary)] mono">
                We onboard 3 companies per cohort. Next cohort starts Q2 2026.
              </p>
            </div>
          </div>

          <ContactForm />
        </div>
      </div>
    </section>

    <!-- ============================== -->
    <!-- FOOTER -->
    <!-- ============================== -->
    <footer class="border-t border-[var(--border)] py-8 sm:py-10 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 sm:gap-6">
          <div class="flex items-center gap-3">
            <div class="w-2 h-2 bg-[var(--lime)]"></div>
            <span class="mono text-sm font-bold tracking-wider">ONBOARD</span>
          </div>

          <div class="flex gap-6 sm:gap-8">
            <a href="https://github.com/arturo-lr-dev/onboard" class="section-label hover:text-[var(--text-primary)] transition-colors">GitHub</a>
            <a href="#" class="section-label hover:text-[var(--text-primary)] transition-colors">Docs</a>
            <a href="mailto:hello@onboard.ai" class="section-label hover:text-[var(--text-primary)] transition-colors">Contact</a>
          </div>
        </div>

        <div class="divider my-5 sm:my-6"></div>

        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 sm:gap-4">
          <p class="text-[10px] sm:text-xs text-[var(--text-tertiary)] mono">
            &copy; 2026 Onboard. Built by ArturoClawd & Arturo.
          </p>
          <p class="text-[10px] sm:text-xs text-[var(--text-tertiary)] mono">
            SYS.STATUS: <span class="text-[var(--lime)]">OPERATIONAL</span>
          </p>
        </div>
      </div>
    </footer>

    <!-- Floating CTA -->
    <div class="floating-cta" id="floating-cta">
      <a href="#contact" class="btn-primary shadow-lg shadow-black/30 text-xs sm:text-[13px]">
        Join Waitlist
        <svg class="w-3.5 sm:w-4 h-3.5 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
      </a>
    </div>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ---- Hero stagger ----
  const heroItems = document.querySelectorAll('.stagger-in > *');
  gsap.fromTo(heroItems,
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power3.out',
      clearProps: 'all'
    }
  );

  // ---- Scroll-triggered sections ----
  // Content is always visible. We only animate a subtle slide-up on enter.
  document.querySelectorAll('.section-reveal').forEach((section) => {
    const children = section.querySelectorAll(':scope > div > *');
    gsap.from(children, {
      y: 30,
      duration: 0.7,
      stagger: 0.08,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 85%',
        toggleActions: 'play none none none',
      }
    });
  });

  // ---- Terminal animation ----
  const terminalLines = [
    { text: '$ onboard deploy --agent sales-copilot', color: 'var(--text-primary)', delay: 600 },
    { text: '', delay: 200 },
    { text: 'Loading context pack: acme-corp-v3.2...', color: 'var(--text-secondary)', delay: 400 },
    { text: '  org_structure.yaml       [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  culture_handbook.md      [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  sales_playbook.md        [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  compliance_policies.json [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '', delay: 200 },
    { text: 'Provisioning access...', color: 'var(--text-secondary)', delay: 500 },
    { text: '  Salesforce CRM        [role: read/write]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '  Slack #sales-team     [role: member]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '  HubSpot               [role: read-only]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '', delay: 200 },
    { text: 'Running compliance checks...', color: 'var(--text-secondary)', delay: 600 },
    { text: '  SOC2 policy      PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '  Data boundaries  PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '  Audit logging    PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '', delay: 300 },
    { text: 'Agent "sales-copilot" deployed successfully.', color: 'var(--lime)', delay: 400, highlight: true },
    { text: 'Time: 4m 32s  |  Status: LIVE', color: 'var(--lime)', delay: 200 },
  ];

  const terminalOutput = document.getElementById('terminal-output');
  if (terminalOutput) {
    let totalDelay = 800;
    terminalLines.forEach((line) => {
      totalDelay += line.delay;
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'terminal-line';
        el.style.color = line.color || 'var(--text-primary)';
        if (line.highlight) el.style.fontWeight = '700';
        el.textContent = line.text || '\u00A0';
        terminalOutput.appendChild(el);
        terminalOutput.scrollTop = terminalOutput.scrollHeight;
      }, totalDelay);
    });

    totalDelay += 400;
    setTimeout(() => {
      const cursor = document.createElement('span');
      cursor.className = 'animate-blink';
      cursor.textContent = '_';
      cursor.style.color = 'var(--lime)';
      const lastLine = document.createElement('div');
      lastLine.className = 'terminal-line';
      lastLine.textContent = '$ ';
      lastLine.style.color = 'var(--text-primary)';
      lastLine.appendChild(cursor);
      terminalOutput.appendChild(lastLine);
    }, totalDelay);
  }

  // ---- Floating CTA ----
  const floatingCta = document.getElementById('floating-cta');
  const contactSection = document.getElementById('contact');

  if (floatingCta) {
    ScrollTrigger.create({
      trigger: '#problem',
      start: 'top 80%',
      onEnter: () => floatingCta.classList.add('visible'),
      onLeaveBack: () => floatingCta.classList.remove('visible'),
    });

    if (contactSection) {
      ScrollTrigger.create({
        trigger: contactSection,
        start: 'top 80%',
        onEnter: () => floatingCta.classList.remove('visible'),
        onLeaveBack: () => floatingCta.classList.add('visible'),
      });
    }
  }

  // ---- Parallax dot grid ----
  const dotGrid = document.querySelector('.dot-grid');
  if (dotGrid) {
    gsap.to(dotGrid, {
      backgroundPosition: '12px 60px',
      ease: 'none',
      scrollTrigger: {
        trigger: dotGrid,
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      }
    });
  }

  // ---- Hero email form ----
  const heroForm = document.getElementById('hero-email') as HTMLFormElement;
  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = heroForm.querySelector('button') as HTMLButtonElement;
    const input = heroForm.querySelector('input[type="email"]') as HTMLInputElement;
    const originalHTML = btn.innerHTML;

    btn.disabled = true;
    btn.innerHTML = '<span class="animate-pulse mono text-xs">SENDING...</span>';

    try {
      const formData = new FormData(heroForm);
      await fetch(heroForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      input.value = '';
      btn.innerHTML = '<span class="mono text-xs">ADDED</span>';
      setTimeout(() => { btn.innerHTML = originalHTML; btn.disabled = false; }, 3000);
    } catch {
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    }
  });
</script>
