<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ---- Hero stagger ----
  const heroItems = document.querySelectorAll('.stagger-in > *');
  gsap.fromTo(heroItems,
    { opacity: 0, y: 30 },
    {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: 'power3.out',
      clearProps: 'all'
    }
  );

  // ---- Scroll-triggered sections ----
  // Content is always visible. We only animate a subtle slide-up on enter.
  document.querySelectorAll('.section-reveal').forEach((section) => {
    const children = section.querySelectorAll(':scope > div > *');
    gsap.from(children, {
      y: 30,
      duration: 0.7,
      stagger: 0.08,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 85%',
        toggleActions: 'play none none none',
      }
    });
  });

  // ---- Terminal animation ----
  const terminalLines = [
    { text: '$ onboard deploy --agent sales-copilot', color: 'var(--text-primary)', delay: 600 },
    { text: '', delay: 200 },
    { text: 'Loading context pack: acme-corp-v3.2...', color: 'var(--text-secondary)', delay: 400 },
    { text: '  org_structure.yaml       [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  culture_handbook.md      [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  sales_playbook.md        [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '  compliance_policies.json [loaded]', color: 'var(--text-tertiary)', delay: 150 },
    { text: '', delay: 200 },
    { text: 'Provisioning access...', color: 'var(--text-secondary)', delay: 500 },
    { text: '  Salesforce CRM        [role: read/write]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '  Slack #sales-team     [role: member]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '  HubSpot               [role: read-only]', color: 'var(--text-tertiary)', delay: 200 },
    { text: '', delay: 200 },
    { text: 'Running compliance checks...', color: 'var(--text-secondary)', delay: 600 },
    { text: '  SOC2 policy      PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '  Data boundaries  PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '  Audit logging    PASS', color: 'var(--green)', delay: 200, highlight: true },
    { text: '', delay: 300 },
    { text: 'Agent "sales-copilot" deployed successfully.', color: 'var(--lime)', delay: 400, highlight: true },
    { text: 'Time: 4m 32s  |  Status: LIVE', color: 'var(--lime)', delay: 200 },
  ];

  const terminalOutput = document.getElementById('terminal-output');
  if (terminalOutput) {
    let totalDelay = 800;
    terminalLines.forEach((line) => {
      totalDelay += line.delay;
      setTimeout(() => {
        const el = document.createElement('div');
        el.className = 'terminal-line';
        el.style.color = line.color || 'var(--text-primary)';
        if (line.highlight) el.style.fontWeight = '700';
        el.textContent = line.text || '\u00A0';
        terminalOutput.appendChild(el);
        terminalOutput.scrollTop = terminalOutput.scrollHeight;
      }, totalDelay);
    });

    totalDelay += 400;
    setTimeout(() => {
      const cursor = document.createElement('span');
      cursor.className = 'animate-blink';
      cursor.textContent = '_';
      cursor.style.color = 'var(--lime)';
      const lastLine = document.createElement('div');
      lastLine.className = 'terminal-line';
      lastLine.textContent = '$ ';
      lastLine.style.color = 'var(--text-primary)';
      lastLine.appendChild(cursor);
      terminalOutput.appendChild(lastLine);
    }, totalDelay);
  }

  // ---- Floating CTA ----
  const floatingCta = document.getElementById('floating-cta');
  const contactSection = document.getElementById('contact');

  if (floatingCta) {
    ScrollTrigger.create({
      trigger: '#problem',
      start: 'top 80%',
      onEnter: () => floatingCta.classList.add('visible'),
      onLeaveBack: () => floatingCta.classList.remove('visible'),
    });

    if (contactSection) {
      ScrollTrigger.create({
        trigger: contactSection,
        start: 'top 80%',
        onEnter: () => floatingCta.classList.remove('visible'),
        onLeaveBack: () => floatingCta.classList.add('visible'),
      });
    }
  }

  // ---- Parallax dot grid ----
  const dotGrid = document.querySelector('.dot-grid');
  if (dotGrid) {
    gsap.to(dotGrid, {
      backgroundPosition: '12px 60px',
      ease: 'none',
      scrollTrigger: {
        trigger: dotGrid,
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      }
    });
  }

  // ---- Hero email form ----
  const heroForm = document.getElementById('hero-email') as HTMLFormElement;
  heroForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = heroForm.querySelector('button') as HTMLButtonElement;
    const input = heroForm.querySelector('input[type="email"]') as HTMLInputElement;
    const originalHTML = btn.innerHTML;

    btn.disabled = true;
    btn.innerHTML = '<span class="animate-pulse mono text-xs">SENDING...</span>';

    try {
      const formData = new FormData(heroForm);
      await fetch(heroForm.action, {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      });

      input.value = '';
      btn.innerHTML = '<span class="mono text-xs">ADDED</span>';
      setTimeout(() => { btn.innerHTML = originalHTML; btn.disabled = false; }, 3000);
    } catch {
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    }
  });
</script>
