---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Onboard - Enterprise AI Agent Onboarding">
  <main class="min-h-screen">
    
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 px-6">
      <!-- Background Elements -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#00D9FF]/10 via-transparent to-transparent pointer-events-none"></div>
      <div class="absolute top-20 right-20 w-96 h-96 bg-[#00D9FF]/5 rounded-full blur-3xl pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="max-w-4xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-[#00D9FF]/10 border border-[#00D9FF]/30 rounded-full px-4 py-2 mb-8">
            <div class="w-2 h-2 bg-[#00D9FF] rounded-full animate-pulse"></div>
            <span class="text-sm font-medium text-[#00D9FF]">Early Access Open</span>
          </div>
          
          <!-- Headline -->
          <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold mb-6 leading-[0.95] tracking-tight">
            Enterprise-Grade<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00D9FF] to-[#00A8CC]">
              Onboarding
            </span><br/>
            for AI Agents
          </h1>
          
          <!-- Subhead -->
          <p class="text-xl md:text-2xl text-gray-400 mb-8 max-w-2xl leading-relaxed">
            Stop deploying agents blindly. Give them context, access, and compliance from day one.
          </p>
          
          <!-- Stats -->
          <div class="flex flex-wrap gap-8 mb-12">
            <div>
              <div class="text-3xl font-bold text-[#00D9FF]">Hours</div>
              <div class="text-sm text-gray-500">not weeks to production</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-[#00D9FF]">100%</div>
              <div class="text-sm text-gray-500">compliant from day one</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-[#00D9FF]">Zero</div>
              <div class="text-sm text-gray-500">security nightmares</div>
            </div>
          </div>
          
          <!-- CTA -->
          <a 
            href="#contact" 
            class="inline-block bg-[#00D9FF] hover:bg-[#00C0E6] text-[#0A1128] font-bold px-8 py-4 rounded-lg transition-all transform hover:scale-105 active:scale-95"
          >
            Request Early Access →
          </a>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="py-20 px-6 bg-[#0F172A]">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-6">
            You Wouldn't Hire a Human<br/>
            <span class="text-gray-400">Without Onboarding</span>
          </h2>
          <p class="text-xl text-gray-400 leading-relaxed">
            When you bring on a new employee, there's a process: culture docs, tool access, compliance training, team introductions. When you deploy an AI agent? Chaos.
          </p>
        </div>

        <!-- Pain Points Grid -->
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-gradient-to-br from-red-500/5 to-transparent border border-red-500/20 rounded-xl p-6">
            <div class="text-4xl mb-4">🔓</div>
            <h3 class="text-xl font-bold mb-2">Security Nightmares</h3>
            <p class="text-gray-400">Ad-hoc credential sharing, unclear permissions, zero audit trails.</p>
          </div>

          <div class="bg-gradient-to-br from-orange-500/5 to-transparent border border-orange-500/20 rounded-xl p-6">
            <div class="text-4xl mb-4">⏱️</div>
            <h3 class="text-xl font-bold mb-2">Weeks to Production</h3>
            <p class="text-gray-400">Manual context loading, custom integrations, endless config files.</p>
          </div>

          <div class="bg-gradient-to-br from-yellow-500/5 to-transparent border border-yellow-500/20 rounded-xl p-6">
            <div class="text-4xl mb-4">⚠️</div>
            <h3 class="text-xl font-bold mb-2">Compliance Blindspots</h3>
            <p class="text-gray-400">No standardization, no policy enforcement, regulators will notice.</p>
          </div>

          <div class="bg-gradient-to-br from-purple-500/5 to-transparent border border-purple-500/20 rounded-xl p-6">
            <div class="text-4xl mb-4">🔄</div>
            <h3 class="text-xl font-bold mb-2">Doesn't Scale</h3>
            <p class="text-gray-400">Onboarding agent #10 is just as painful as agent #1.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="py-20 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-6">
            The Infrastructure Layer<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00D9FF] to-[#00A8CC]">
              AI Ops Has Been Missing
            </span>
          </h2>
          <p class="text-xl text-gray-400">
            Onboard makes deploying AI agents as structured and secure as hiring humans.
          </p>
        </div>

        <!-- Features -->
        <div class="grid md:grid-cols-3 gap-8">
          <div class="border border-gray-800 rounded-xl p-8 hover:border-[#00D9FF]/50 transition-all">
            <div class="w-12 h-12 bg-[#00D9FF]/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[#00D9FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Context Loading</h3>
            <p class="text-gray-400 leading-relaxed">
              Upload your org structure, processes, culture docs. Agents start with full company context from day one.
            </p>
          </div>

          <div class="border border-gray-800 rounded-xl p-8 hover:border-[#00D9FF]/50 transition-all">
            <div class="w-12 h-12 bg-[#00D9FF]/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[#00D9FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Access Management</h3>
            <p class="text-gray-400 leading-relaxed">
              Role-based permissions, automated secret rotation, zero ad-hoc credential sharing. Security built-in.
            </p>
          </div>

          <div class="border border-gray-800 rounded-xl p-8 hover:border-[#00D9FF]/50 transition-all">
            <div class="w-12 h-12 bg-[#00D9FF]/10 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-[#00D9FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Compliance Ready</h3>
            <p class="text-gray-400 leading-relaxed">
              Audit trails, policy enforcement, SOC2-ready logs. Regulators happy, security team happy.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20 px-6 bg-[#0F172A]">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-bold mb-4">
            Ready to Deploy Agents<br/>
            <span class="text-[#00D9FF]">The Right Way?</span>
          </h2>
          <p class="text-xl text-gray-400">
            Join the waitlist for early access. Limited spots available for pilot companies.
          </p>
        </div>

        <ContactForm />
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 px-6 border-t border-gray-800">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <div>
            <div class="text-2xl font-bold mb-2">Onboard</div>
            <p class="text-gray-500 text-sm">Enterprise-grade onboarding for AI agents.</p>
          </div>
          
          <div class="flex gap-6 text-sm text-gray-500">
            <a href="https://github.com/yourusername/onboard" class="hover:text-[#00D9FF] transition-colors">GitHub</a>
            <a href="#" class="hover:text-[#00D9FF] transition-colors">Docs</a>
            <a href="mailto:hello@onboard.ai" class="hover:text-[#00D9FF] transition-colors">Contact</a>
          </div>
        </div>
        
        <div class="mt-8 pt-6 border-t border-gray-800 text-center text-sm text-gray-600">
          © 2026 Onboard. Built by ArturoClawd & Arturo.
        </div>
      </div>
    </footer>

  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animate hero on load
  gsap.from('h1', {
    opacity: 0,
    y: 30,
    duration: 1,
    ease: 'power3.out'
  });

  // Animate sections on scroll
  gsap.utils.toArray('section').forEach((section: any, i) => {
    if (i > 0) { // Skip hero
      gsap.from(section, {
        opacity: 0,
        y: 50,
        duration: 0.8,
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: 'top 50%',
          scrub: 1,
        }
      });
    }
  });
</script>
</Layout>
